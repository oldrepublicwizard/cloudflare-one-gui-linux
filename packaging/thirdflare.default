# ThirdFlare One — systemd EnvironmentFile (Debian/RHEL idiomatic)
# Install to /etc/default/thirdflare or reference from a systemd drop-in.
#
# Precedence (low → high): defaults → /etc/thirdflare/config.json → this file →
# ~/.config/thirdflare/config.json → in-app session overrides.

THIRDFLARE_PORT=4173
THIRDFLARE_BIND=127.0.0.1
THIRDFLARE_WEBUI=0
THIRDFLARE_WEBUI_ALLOW_REMOTE=0
# THIRDFLARE_WARP_CLI=/usr/bin/warp-cli
