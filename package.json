{
  "name": "cloudflare-one-gui-linux",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Linux desktop-style GUI for managing Cloudflare WARP through warp-cli.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "check": "node --check server.js && node --check public/app.js && node --check public/service-worker.js && node --check scripts/health-check.mjs && node --check scripts/port-open.mjs",
    "install:desktop": "bash scripts/install-desktop-entry.sh",
    "uninstall:desktop": "bash scripts/uninstall-desktop-entry.sh",
    "install:user-service": "bash scripts/install-user-service.sh",
    "uninstall:user-service": "bash scripts/uninstall-user-service.sh",
    "package:stage": "bash packaging/scripts/stage-payload.sh",
    "package:deb": "bash packaging/scripts/build-deb-rpm.sh deb",
    "package:rpm": "bash packaging/scripts/build-deb-rpm.sh rpm",
    "package:arch": "bash packaging/scripts/build-deb-rpm.sh arch",
    "package:appimage": "bash packaging/scripts/build-appimage.sh",
    "package:flatpak": "bash packaging/scripts/build-flatpak.sh",
    "package:snap": "bash packaging/scripts/build-snap.sh",
    "package:source": "bash packaging/scripts/build-source.sh",
    "package:checksums": "bash packaging/scripts/checksums.sh"
  }
}
